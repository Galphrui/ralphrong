<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_panel"
    android:orientation="vertical"
    android:padding="16dp"
    tools:background="@color/ra_bg">

    <TextView
        style="@style/RaLabel"
        android:text="RA VISIT RECORD" />

    <TextView
        android:id="@+id/stats_hint"
        style="@style/RaParagraph"
        tools:text="统计已刷新。" />

    <TextView
        android:id="@+id/stats_visits"
        style="@style/RaVerticalStat"
        tools:text="83&#10;全站访问次数" />

    <TextView
        android:id="@+id/stats_visitors"
        style="@style/RaVerticalStat"
        tools:text="8&#10;全站访客数" />

    <TextView
        android:id="@+id/stats_last_visit"
        style="@style/RaVerticalStat"
        tools:text="06/24 18:36&#10;最近访问时间" />

    <TextView
        android:id="@+id/stats_device"
        style="@style/RaVerticalStat"
        tools:text="RA-DEVICE&#10;本机访客标识" />
</LinearLayout>
