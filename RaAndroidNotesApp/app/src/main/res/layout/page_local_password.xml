<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_panel"
    android:orientation="vertical"
    android:padding="16dp"
    tools:background="@color/ra_bg">

    <TextView
        style="@style/RaSectionTitle"
        android:text="本机密码" />

    <EditText
        android:id="@+id/local_user"
        style="@style/RaInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="本机账号"
        tools:text="RaLocal" />

    <EditText
        android:id="@+id/local_old_password"
        style="@style/RaInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="旧本机密码"
        android:inputType="textPassword" />

    <EditText
        android:id="@+id/local_new_password"
        style="@style/RaInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="新本机密码"
        android:inputType="textPassword" />

    <TextView
        android:id="@+id/local_save_password"
        style="@style/RaPrimaryAction"
        android:text="保存本机密码" />

    <TextView
        android:id="@+id/local_back_admin"
        style="@style/RaSecondaryAction"
        android:text="返回后台登录" />
</LinearLayout>
